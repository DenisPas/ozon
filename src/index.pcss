:root {
	font-family: system-ui, avenir, helvetica, arial, sans-serif;
	line-height: 1.5;
	font-weight: 400;
	color-scheme: light dark;
}

* {
	box-sizing: border-box;
}

body {
	margin: 0;
	min-height: 100vh;
}

a {
	color: #646cff;
	text-decoration: none;
}

a:hover {
	text-decoration: underline;
}
